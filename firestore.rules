rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all reads and writes by default across the entire database
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for User documents and subcollections (user isolation)
    match /users/{userId} {
      // Users can only read or write their own root document
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // All nested collections (transactions, months, etc.) inherit the same protection
      match /{subcollection=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
